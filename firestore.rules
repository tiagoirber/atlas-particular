rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.uid in [
          "ouWnI4m0G1hPk7zHfXrUMziBGEu2",
          "5uybKsChJDM9XTaGhAYgPd72MHc2"
        ];
    }

    function isPublishedPublic(trip) {
      return trip.status == "published" && trip.isPublic == true;
    }

    // Coleção raiz de viagens
    match /trips/{tripId} {
      allow read: if isAdmin() || isPublishedPublic(resource.data);
      allow create, update, delete: if isAdmin();

      match /days/{dayId} {
        allow read: if isAdmin()
          || isPublishedPublic(get(/databases/$(database)/documents/trips/$(tripId)).data);
        allow create, update, delete: if isAdmin();
      }

      match /attractions/{attractionId} {
        allow read: if isAdmin()
          || isPublishedPublic(get(/databases/$(database)/documents/trips/$(tripId)).data);
        allow create, update, delete: if isAdmin();
      }
    }

    // Perfis (opcional). Apenas o próprio admin lê/edita seu doc.
    match /users/{userId} {
      allow read, write: if isAdmin() && request.auth.uid == userId;
    }

    // Default deny — qualquer outra rota é bloqueada.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
