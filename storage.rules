rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches("image/(jpeg|jpg|png|webp)");
    }

    function isVideo() {
      return request.resource.contentType.matches("video/(mp4|webm|quicktime|x-m4v)");
    }

    function imageSizeOk() {
      return request.resource.size <= 8 * 1024 * 1024; // 8 MB
    }

    function videoSizeOk() {
      return request.resource.size <= 500 * 1024 * 1024; // 500 MB
    }

    // Pastas estruturadas em trips/{tripId}/...
    // All authenticated users can upload to trips (app enforces ownership)
    match /trips/{tripId}/{allPaths=**} {
      // Leitura pública dos arquivos é necessária para mostrar imagens
      // de viagens publicadas — o Firestore controla a visibilidade
      // de quais viagens existem.
      allow read: if true;

      // Allow authenticated users to write/delete (Firestore enforces trip ownership)
      allow write, delete: if isAuthenticated() && (
        (isImage() && imageSizeOk()) ||
        (isVideo() && videoSizeOk())
      );
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
